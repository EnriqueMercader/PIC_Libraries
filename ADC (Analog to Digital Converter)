void adc_Initialization(char numberOfAnalogChannels) {
    ADCON1 = numberOfAnalogChannels;      // Ref voltage is VDD and Configure pin as analog pin 
    ADCON2 = 0x92;      // Right Justified, 4Tad and Fosc/32
    ADRESH = 0;         // Flush ADC output Register
    ADRESL = 0;
}

void adc_Read(int channel) {
    // Function Variable
    float analogVoltage = 0;

    // Function Code
    ADCON0 = (ADCON0 & 0b11000011) | ((channel << 2) & 0b00111100);  // Select the channel and disable ADC
    ADCON0 |= ((1 << ADON) | (1 << GO));                            // Enable ADC and start conversion

    // Wait for End of conversion
    while (ADCON0bits.GO_nDONE == 1) {
        // You can put other code here if needed
    }

    analogVoltage = (float)((ADRESH * 256) + ADRESL) * 5 / 1023;  // Convert digital value into analog voltage
    integer = (int)analogVoltage;                              // Extract the integer part
    decimal = (int)((analogVoltage - integer) * 100);        // Extract the decimal part with two decimal places
}
